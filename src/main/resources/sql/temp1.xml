<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
  PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
  "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="temp1">
  
  <select id="findList" parameterType="Object" resultType="HashMap">
  	SELECT * FROM temp1 
  	<if test="accept == 1">
  		WHERE accept = 1
  	</if>
  	<if test="accept == 0">
  		WHERE accept = 0
  	</if>
  </select>
  
</mapper>